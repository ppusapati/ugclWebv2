        {
          "id": "upload_the_diesel_bill_photo",
          "type": "file_upload",
          "label": "Diesel Bill Photo",
          "hint": "Upload diesel bill",
          "required": true,
          "multiple": true,
          "accept": "image/*",
          "maxFiles": 10,
          "maxSizePerFile": 10485760
