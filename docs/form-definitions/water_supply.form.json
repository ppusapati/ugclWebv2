          "type": "number",
          "label": "Capacity (Liters)",
          "hint": "Enter tank capacity in liters",
          "required": true,
          "min": 0,
          "step": 0.01,
          "suffix": "L"
        },
        {
          "id": "rate_per_unit",
          "type": "number",
          "label": "Rate per Unit (Rs/Ltr)",
          "hint": "Enter rate per liter (optional)",
          "required": false,
          "min": 0,
          "step": 0.01,
          "prefix": "₹"
        },
        {
          "id": "photos",
          "type": "file_upload",
          "label": "Tanker Photos",
          "hint": "Upload photos of tanker",
          "required": true,
          "multiple": true,
          "accept": "image/*",
          "maxFiles": 10,
          "maxSizePerFile": 10485760
        },
        {
          "id": "supplier_name",
          "type": "text",
          "label": "Supplier Name",
          "hint": "Enter water supplier's name",
          "required": true
        },
        {
          "id": "supplier_phone",
          "type": "text",
          "label": "Supplier Phone Number",
          "hint": "Enter phone number of supplier",
          "required": true,
          "validation": {
            "pattern": "^[0-9+ -]{10,15}$",
