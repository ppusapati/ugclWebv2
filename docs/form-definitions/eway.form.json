{
  "form_code": "EWAY",
  "title": "E-Way Bill Entry",
  "description": "Form to record E-Way bill details including transporter, items, dispatch, and tax details",
  "version": "1.0.0",
  "module": "accounts",
  "accessible_verticals": [
    "WATER"
  ],
  "type": "single_page",
  "steps": [
    {
      "id": "step_1",
      "title": "E-Way Bill Entry",
      "description": "E-Way bill capture",
      "fields": [
        {
          "id": "bill_no",
          "type": "text",
          "label": "Bill Number",
          "hint": "Enter bill number",
          "required": true
        },
        {
          "id": "generated_date",
          "type": "date",
          "label": "Generated Date",
          "hint": "Select generation date",
          "required": true
        },
        {
          "id": "generated_by",
          "type": "text",
          "label": "Generated By",
          "hint": "Enter name of generator",
          "required": true
        },
        {
          "id": "valid_upto",
          "type": "date",
          "label": "Valid Upto",
          "hint": "Enter bill validity date (optional)",
          "required": false
        },
        {
          "id": "mode",
          "type": "dropdown",
          "label": "Mode of Transport",
          "hint": "Select transport mode",
          "required": false,
          "options": [
            { "label": "Road", "value": "road" },
            { "label": "Rail", "value": "rail" },
            { "label": "Ship", "value": "ship" },
            { "label": "Air Cargo", "value": "air_cargo" },
            { "label": "Others", "value": "others" }
          ]
        },
        {
          "id": "type",
          "type": "dropdown",
          "label": "Movement Type",
          "hint": "Select inward/outward/own use",
          "required": false,
          "options": [
            { "label": "Inward", "value": "inward" },
            { "label": "Outward", "value": "outward" },
            { "label": "Own use", "value": "own_use" }
          ]
        },
        {
          "id": "document_details",
          "type": "text",
          "label": "Document Details",
          "hint": "Enter document details (optional)",
          "required": false
        },
        {
          "id": "dispatch_from",
          "type": "text",
          "label": "Dispatch From",
          "hint": "Enter dispatch location",
          "required": true
        },
        {
          "id": "dispatch_pincode",
          "type": "text",
          "label": "Dispatch Pincode",
          "hint": "Enter dispatch area pincode",
          "required": true,
          "validation": {
            "pattern": "^[0-9]{6}$",
            "message": "Enter a valid 6-digit pincode"
          }
        },
        {
          "id": "ship_to_address",
          "type": "text",
          "label": "Ship To Address",
          "hint": "Enter destination address (optional)",
          "required": false
        },
        {
          "id": "ship_to_pincode",
          "type": "text",
          "label": "Ship To Pincode",
          "hint": "Enter destination pincode",
          "required": true,
          "validation": {
            "pattern": "^[0-9]{6}$",
            "message": "Enter a valid 6-digit pincode"
          }
        },
        {
          "id": "product_name",
          "type": "dropdown",
          "label": "Product Name",
          "hint": "Select product name",
          "required": true,
          "options": [
            { "label": "HDPE PN 6", "value": "hdpe_pn_6" },
            { "label": "HDPE PN8", "value": "hdpe_pn8" },
            { "label": "HDPE PN 10", "value": "hdpe_pn_10" },
            { "label": "HDPE PN 12.5", "value": "hdpe_pn_12_5" },
            { "label": "HDPE SPECIALS", "value": "hdpe_specials" },
            { "label": "DI K7", "value": "di_k7" },
            { "label": "DI K9", "value": "di_k9" },
            { "label": "DI SPECIALS", "value": "di_specials" },
            { "label": "MS E350", "value": "ms_e350" },
            { "label": "MS E250", "value": "ms_e250" },
            { "label": "PVC ITEMS", "value": "pvc_items" },
            { "label": "GI PIPES", "value": "gi_pipes" },
            { "label": "MS SPECIALS", "value": "ms_specials" },
            { "label": "BT PRIMER", "value": "bt_primer" },
            { "label": "WRAPPING ROLLS", "value": "wrapping_rolls" },
            { "label": "EPOXY PRIMER", "value": "epoxy_primer" },
            { "label": "SURFACE COAT PAINT", "value": "surface_coat_paint" },
            { "label": "DG", "value": "dg" },
            { "label": "FUSION MECHINE", "value": "fusion_mechine" },
            { "label": "BUD JOINT MECHINE", "value": "bud_joint_mechine" },
            { "label": "VIBRATOR", "value": "vibrator" },
            { "label": "CENTRING MATERIAL", "value": "centring_material" },
            { "label": "STUB ENDS", "value": "stub_ends" },
            { "label": "PRESSURE GUAGE", "value": "pressure_guage" },
            { "label": "CEMENT 53 GRADE", "value": "cement_53_grade" },
            { "label": "CEMENT 43 GRADE", "value": "cement_43_grade" },
            { "label": "STEEL", "value": "steel" },
            { "label": "CRUSHER MARERIAL", "value": "crusher_marerial" },
            { "label": "READY MIX", "value": "ready_mix" },
            { "label": "SAFETY ITEMS", "value": "safety_items" },
            { "label": "OTHERS", "value": "others" }
          ]
        },
        {
          "id": "special_item_description",
          "type": "dropdown",
          "label": "Special Item Description",
          "hint": "Optional special item",
          "required": false,
          "options": [
            { "label": "PIPE", "value": "pipe" },
            { "label": "COUPLER", "value": "coupler" },
            { "label": "REDUCER", "value": "reducer" },
            { "label": "BENDS", "value": "bends" },
            { "label": "TEE", "value": "tee" },
            { "label": "AIR VALVES", "value": "air_valves" },
            { "label": "HYDRANT TEE", "value": "hydrant_tee" },
            { "label": "MECHANICAL JOINT COLLAR", "value": "mechanical_joint_collar" },
            { "label": "GASKETS", "value": "gaskets" },
            { "label": "WELDING RODS", "value": "welding_rods" },
            { "label": "8 MM", "value": "8_mm" },
            { "label": "10 MM", "value": "10_mm" },
            { "label": "12 MM", "value": "12_mm" },
            { "label": "16 MM", "value": "16_mm" },
            { "label": "20 MM", "value": "20_mm" },
            { "label": "40 MM", "value": "40_mm" },
            { "label": "M SAND", "value": "m_sand" },
            { "label": "GSB", "value": "gsb" },
            { "label": "WETMIX", "value": "wetmix" },
            { "label": "M15", "value": "m15" },
            { "label": "M20", "value": "m20" },
            { "label": "M25", "value": "m25" },
            { "label": "M30", "value": "m30" },
            { "label": "SAFETY HELMETS", "value": "safety_helmets" },
            { "label": "JACKETS", "value": "jackets" },
            { "label": "SHOES", "value": "shoes" },
            { "label": "BARRICAEDS", "value": "barricaeds" },
            { "label": "CAUTION TAPE", "value": "caution_tape" },
            { "label": "SAFETY CONES", "value": "safety_cones" },
            { "label": "OTHERS", "value": "others" }
          ]
        },
        {
          "id": "pipe_dia",
          "type": "dropdown",
          "label": "Pipe Diameter",
          "hint": "Select pipe diameter (optional)",
          "required": false,
          "options": [
            { "label": "63", "value": "63" },
            { "label": "75", "value": "75" },
            { "label": "90", "value": "90" },
            { "label": "100", "value": "100" },
            { "label": "110", "value": "110" },
            { "label": "125", "value": "125" },
            { "label": "140", "value": "140" },
            { "label": "150", "value": "150" },
            { "label": "160", "value": "160" },
            { "label": "180", "value": "180" },
            { "label": "200", "value": "200" },
            { "label": "225", "value": "225" },
            { "label": "250", "value": "250" },
            { "label": "273", "value": "273" },
            { "label": "323.5", "value": "323.5" },
            { "label": "355", "value": "355" },
            { "label": "406", "value": "406" },
            { "label": "457", "value": "457" },
            { "label": "508", "value": "508" },
            { "label": "610", "value": "610" },
            { "label": "NA", "value": "na" }
          ]
        },
        {
          "id": "uom",
          "type": "dropdown",
          "label": "UOM (Unit of Measure)",
          "hint": "Select unit of measure (optional)",
          "required": false,
          "options": [
            { "label": "MTRS", "value": "mtrs" },
            { "label": "LTRS", "value": "ltrs" },
            { "label": "Others", "value": "others" }
          ]
        },
        {
          "id": "quantity",
          "type": "number",
          "label": "Quantity",
          "hint": "Enter quantity",
          "required": true,
          "min": 0,
          "step": 0.01
        },
        {
          "id": "hsn_code",
          "type": "text",
          "label": "HSN Code",
          "hint": "Enter HSN code (optional)",
          "required": false
        },
        {
          "id": "taxable_amount",
          "type": "number",
          "label": "Taxable Amount (₹)",
          "hint": "Enter taxable amount (optional)",
          "required": false,
          "prefix": "₹",
          "min": 0,
          "step": 0.01
        },
        {
          "id": "transporter_id_name",
          "type": "text",
          "label": "Transporter ID / Name",
          "hint": "Enter transporter info (optional)",
          "required": false
        },
        {
          "id": "transporter_doc_no",
          "type": "text",
          "label": "Transporter Document No.",
          "hint": "Enter doc number (optional)",
          "required": false
        },
        {
          "id": "document_date",
          "type": "date",
          "label": "Document Date",
          "hint": "Optional document date",
          "required": false
        },
        {
          "id": "vehicle_no",
          "type": "text",
          "label": "Vehicle Number",
          "hint": "Enter vehicle number (optional)",
          "required": false
        },
        {
          "id": "entered_date",
          "type": "date",
          "label": "Entered Date",
          "hint": "Date of record entry",
          "required": true
        },
        {
          "id": "remarks",
          "type": "textarea",
          "label": "Remarks",
          "hint": "Additional remarks (optional)",
          "required": false,
          "rows": 3,
          "maxLength": 500
        }
      ]
    }
  ],
  "validations": {},
  "permissions": {
    "create": "*",
    "read": "*",
    "update": "*",
    "delete": "*",
    "approve": "*"
  },
  "ui_config": {
    "show_progress": false,
    "allow_save_draft": true,
    "submit_button_text": "Submit E-Way Bill",
    "success_message": "E-Way bill entry submitted successfully.",
    "error_message": "Unable to submit E-Way bill entry. Please check the form and try again."
  }
}
