{
  "form_code": "STOCK",
  "title": "Stock Entry Form",
  "description": "Form for recording incoming or outgoing stock details",
  "version": "1.0.0",
  "module": "accounts",
  "accessible_verticals": [
    "WATER"
  ],
  "type": "single_page",
