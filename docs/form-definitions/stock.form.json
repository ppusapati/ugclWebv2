  "validations": {},
  "permissions": {
    "create": "*",
    "read": "*",
    "update": "*",
    "delete": "*",
    "approve": "*"
  },
  "ui_config": {
    "show_progress": false,
    "allow_save_draft": true,
    "submit_button_text": "Submit Stock Entry",
    "success_message": "Stock entry submitted successfully.",
    "error_message": "Unable to submit stock entry. Please check the form and try again."
  }
}
