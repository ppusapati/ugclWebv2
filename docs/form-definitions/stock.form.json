          "id": "in_out",
          "type": "dropdown",
          "label": "In/Out",
          "hint": "Select In or Out",
          "required": true,
          "options": [
            { "label": "Material Inward", "value": "material_inward" },
            { "label": "Material Outward", "value": "material_outward" },
            { "label": "Material Returned", "value": "material_returned" }
          ]
        },
        {
          "id": "yard_name",
          "type": "dropdown",
          "label": "Yard Name",
          "hint": "Enter yard name",
          "required": true,
          "options": [
