          "type": "text",
          "label": "Label Number",
          "hint": "Enter label number",
          "required": true
        },
        {
          "id": "vehicle_number",
          "type": "text",
          "label": "Vehicle Number",
          "hint": "Enter vehicle number",
          "required": true
        },
        {
          "id": "remarks",
          "type": "textarea",
          "label": "Remarks",
          "hint": "Enter remarks (optional)",
          "required": false,
          "rows": 3,
          "maxLength": 500
        },
        {
          "id": "challan_files",
          "type": "file_upload",
          "label": "Challan Files",
          "hint": "Upload challan files",
          "required": true,
          "multiple": true,
          "accept": ".pdf,.jpg,.jpeg,.png,.doc,.docx",
          "maxFiles": 10,
          "maxSizePerFile": 10485760
        }
