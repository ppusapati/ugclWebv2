{
  "form_code": "CONTRACTOR",
  "title": "Contractor Work Entry",
  "description": "Form to record contractor's daily activity, diesel usage, and supporting photos",
  "version": "1.0.0",
  "module": "accounts",
  "accessible_verticals": [
    "WATER"
  ],
  "type": "single_page",
  "steps": [
    {
      "id": "step_1",
      "title": "Contractor Work Entry",
      "description": "Daily contractor activity capture",
      "fields": [
        {
          "id": "site_name",
          "type": "dropdown",
          "label": "Site Name",
          "hint": "Select work site",
          "placeholder": "Site Name",
          "required": true,
          "dataSource": "api",
          "apiEndpoint": "business/{vertical}/sites/my-access",
          "displayField": "name",
          "valueField": "id",
          "validation": {
            "required": true,
            "message": "Please select a site"
          }
        },
        {
          "id": "contractor_name",
          "type": "dropdown",
          "label": "Contractor Name",
          "hint": "Select contractor name",
          "required": true,
          "options": [
            { "label": "AK ENTERPRISES", "value": "AK ENTERPRISES" },
            { "label": "APR NAYAK PROJECTS", "value": "APR NAYAK PROJECTS" },
            { "label": "AV CONSTRUCTIONS", "value": "AV CONSTRUCTIONS" },
            { "label": "CHALLA EDUKONDALU", "value": "CHALLA EDUKONDALU" },
            { "label": "CK CONSTRUCTIONS", "value": "CK CONSTRUCTIONS" },
            { "label": "CMN ENTERPRISES", "value": "CMN ENTERPRISES" },
            { "label": "GIRISH TD", "value": "GIRISH TD" },
            { "label": "SLV ENTERPRISES", "value": "SLV ENTERPRISES" },
            { "label": "MVR CONSTRUCTIONS", "value": "MVR CONSTRUCTIONS" },
            { "label": "PARAM BANDAWATH INFRASTRUCTURES", "value": "PARAM BANDAWATH INFRASTRUCTURES" },
            { "label": "PRAVEEN NAYAK", "value": "PRAVEEN NAYAK" },
            { "label": "PUTTAMRAJU", "value": "PUTTAMRAJU" },
            { "label": "RAMU AMBU CHAWAN", "value": "RAMU AMBU CHAWAN" },
            { "label": "RUDRAPPA", "value": "RUDRAPPA" },
            { "label": "SKS ENTERPRISES", "value": "SKS ENTERPRISES" },
            { "label": "SRI LAKSHMI ENTERPRISES", "value": "SRI LAKSHMI ENTERPRISES" },
            { "label": "KT THIMMARAJU", "value": "KT THIMMARAJU" },
            { "label": "SRI RAMULU", "value": "SRI RAMULU" },
            { "label": "UGCL - MAGADI", "value": "UGCL - MAGADI" },
            { "label": "UGCL- RAMNAGARA", "value": "UGCL- RAMNAGARA" },
            { "label": "VADDE GOPAL", "value": "VADDE GOPAL" },
            { "label": "VRHR ENGINEERING PVT LTD", "value": "VRHR ENGINEERING PVT LTD" },
            { "label": "STAR KARAVALA", "value": "STAR KARAVALA" },
            { "label": "OTHERS", "value": "OTHERS" }
          ]
        },
        {
          "id": "contractor_phone",
          "type": "text",
          "label": "Contractor Phone Number",
          "hint": "Enter contractor phone number",
          "required": true,
          "validation": {
            "pattern": "^[0-9+ -]{10,15}$",
            "message": "Enter a valid phone number"
          }
        },
        {
          "id": "chainage_from",
          "type": "text",
          "label": "Chainage From",
          "hint": "Enter starting chainage",
          "required": true
        },
        {
          "id": "chainage_to",
          "type": "text",
          "label": "Chainage To",
          "hint": "Enter ending chainage",
          "required": true
        },
        {
          "id": "actual_meters",
          "type": "number",
          "label": "Actual Meters Laid",
          "hint": "Enter laid meters",
          "required": true,
          "min": 0,
          "step": 0.01
        },
        {
          "id": "diesel_taken",
          "type": "number",
          "label": "Diesel Taken (Litres)",
          "hint": "Enter diesel quantity taken",
          "required": true,
          "min": 0,
          "step": 0.01,
          "suffix": "L"
        },
        {
          "id": "vehicle_type",
          "type": "dropdown",
          "label": "Vehicle Type",
          "hint": "Select vehicle type (optional)",
          "required": false,
          "options": [
            { "label": "Vehcile", "value": "vehcile" },
            { "label": "Machinery", "value": "machinery" }
          ]
        },
        {
          "id": "working_hours",
          "type": "text",
          "label": "Working Hours",
          "hint": "Enter total working hours (optional)",
          "required": false
        },
        {
          "id": "meter_photos",
          "type": "file_upload",
          "label": "Diesel Meter Photos",
          "hint": "Upload diesel meter photos",
          "required": true,
          "multiple": true,
          "accept": "image/*",
          "maxFiles": 10,
          "maxSizePerFile": 10485760
        },
        {
          "id": "card_number",
          "type": "dropdown",
          "label": "Card Number",
          "hint": "Select card number",
          "required": true,
          "options": [
            { "label": "CORSREE626500012", "value": "CORSREE626500012" },
            { "label": "CORSREE626500013", "value": "CORSREE626500013" },
            { "label": "CORSREE626500014", "value": "CORSREE626500014" },
