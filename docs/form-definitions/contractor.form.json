            { "label": "UGCL:2528", "value": "UGCL:2528" },
            { "label": "OTHERS(IF ANY LOCAL PURCHASE SELECT)", "value": "OTHERS(IF ANY LOCAL PURCHASE SELECT)" }
          ]
        },
        {
          "id": "area_photos",
          "type": "file_upload",
          "label": "Area Work Photos",
          "hint": "Upload photos of work area",
          "required": true,
          "multiple": true,
          "accept": "image/*",
          "maxFiles": 10,
          "maxSizePerFile": 10485760
        }
      ]
    }
  ],
  "validations": {},
  "permissions": {
    "create": "*",
    "read": "*",
    "update": "*",
    "delete": "*",
    "approve": "*"
  },
  "ui_config": {
    "show_progress": false,
    "allow_save_draft": true,
    "submit_button_text": "Submit Contractor Work",
    "success_message": "Contractor work entry submitted successfully.",
    "error_message": "Unable to submit contractor work entry. Please check the form and try again."
  }
}
